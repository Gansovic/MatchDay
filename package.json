{
  "name": "matchday",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "dev:init": "node scripts/dev-init.js",
    "dev:init:force": "node scripts/dev-init.js --force --verbose",
    "dev:reset": "node scripts/dev-reset.js",
    "dev:reset:hard": "node scripts/dev-reset.js --hard",
    "dev:full": "npm run dev:init && npm run dev",
    "dev:create-users": "node scripts/create-development-users.js",
    "dev:setup": "npm run dev:create-users",
    "auth:check": "node scripts/validate-auth-migration.js",
    "auth:pre-migration": "node scripts/validate-auth-migration.js --pre",
    "auth:post-migration": "node scripts/validate-auth-migration.js --post",
    "auth:recover": "node scripts/validate-auth-migration.js --post --auto-fix",
    "auth:test": "node scripts/test-auth-reliability.js",
    "auth:test-verbose": "node scripts/test-auth-reliability.js --verbose",
    "test:errors": "node scripts/test-error-handling.js",
    "test:errors-verbose": "node scripts/test-error-handling.js --verbose",
    "errors:monitor": "echo 'Visit http://localhost:3000/dev/errors for error monitoring dashboard'"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@tanstack/react-query": "^5.61.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "next": "15.4.6",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@supabase/supabase-js": "^2.55.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^6.0.3",
    "babel-jest": "^29.7.0",
    "dotenv": "^17.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^15.2.11",
    "msw": "^2.10.5",
    "prettier": "^3.4.2",
    "supertest": "^7.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
